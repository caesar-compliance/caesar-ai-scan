{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CaesarEvidenceExportPack",
  "type": "OBJECT",
  "required": [
    "schema_version",
    "pack_id",
    "generated_at",
    "source_tool",
    "source_tool_version",
    "target_project",
    "manifest",
    "scan_result",
    "evidence_candidates",
    "review_workflow",
    "import_readiness",
    "human_review_checklist",
    "integration_notes"
  ],
  "properties": {
    "schema_version": {
      "type": "STRING",
      "const": "0.4.0"
    },
    "pack_id": {
      "type": "STRING"
    },
    "generated_at": {
      "type": "STRING",
      "format": "date-time"
    },
    "source_tool": {
      "type": "STRING"
    },
    "source_tool_version": {
      "type": "STRING"
    },
    "target_project": {
      "type": "STRING"
    },
    "manifest": {
      "type": "OBJECT"
    },
    "scan_result": {
      "type": "OBJECT"
    },
    "evidence_candidates": {
      "type": "ARRAY",
      "items": {
        "type": "OBJECT"
      }
    },
    "review_workflow": {
      "type": "OBJECT"
    },
    "import_readiness": {
      "type": "OBJECT"
    },
    "human_review_checklist": {
      "type": "OBJECT"
    },
    "integration_notes": {
      "type": "STRING"
    }
  }
}
