{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Caesar AI Scan Export Bundle Schema",
  "version": "0.11.0",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_type",
    "bundle_id",
    "generated_at",
    "tool",
    "source",
    "artifacts",
    "artifact_checksums",
    "summary",
    "import_contract",
    "safety"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "0.11.0" },
    "bundle_type": { "type": "string", "const": "caesar-ai-scan-export-bundle" },
    "bundle_id": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "target_path": { "type": "string" },
        "scan_mode": { "type": "string" },
        "generated_from_fixture": { "type": "boolean" }
      }
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "scan_result": { "type": "string" },
        "evidence_candidates": { "type": "string" },
        "review_summary": { "type": "string" },
        "ai_usage_inventory": { "type": "string" }
      }
    },
    "artifact_checksums": { "type": "object" },
    "summary": {
      "type": "object",
      "properties": {
        "finding_count": { "type": "integer" },
        "evidence_candidate_count": { "type": "integer" },
        "inventory_component_count": { "type": "integer" },
        "review_required": { "type": "boolean" },
        "export_status": { "type": "string" }
      }
    },
    "import_contract": {
      "type": "object",
      "properties": {
        "import_status": { "type": "string", "const": "candidate" },
        "backend_ready": { "type": "boolean", "const": true },
        "requires_human_review": { "type": "boolean", "const": true },
        "allowed_ingestion_mode": { "type": "string", "const": "offline_review_only" }
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "secrets_redacted": { "type": "boolean", "const": true },
        "no_external_fetching": { "type": "boolean", "const": true },
        "no_live_ingestion": { "type": "boolean", "const": true },
        "no_customer_data_required": { "type": "boolean", "const": true }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
