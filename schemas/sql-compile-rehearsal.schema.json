{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SQL Compile Rehearsal Report",
  "type": "object",
  "properties": {
    "version": { "type": "string" },
    "timestamp": { "type": "string" },
    "status": { "enum": ["success", "failure"] },
    "rehearsalFiles": {
      "type": "object",
      "properties": {
        "forward": { "type": "string" },
        "rollback": { "type": "string" }
      },
      "required": ["forward", "rollback"]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "description": { "type": "string" },
          "status": { "enum": ["pass", "fail"] },
          "details": { "type": "string" }
        },
        "required": ["id", "description", "status"]
      }
    }
  },
  "required": ["version", "timestamp", "status", "rehearsalFiles", "checks"]
}
