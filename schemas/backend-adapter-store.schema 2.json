{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Caesar AI Scan Local JSON Store",
  "type": "object",
  "properties": {
    "schema_version": { "type": "string", "const": "0.13.0" },
    "store_type": { "type": "string", "const": "caesar-ai-scan-local-json-store" },
    "store_id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "source_import": {
      "type": "object",
      "properties": {
        "import_id": { "type": "string" },
        "import_type": { "type": "string" },
        "schema_version": { "type": "string" },
        "import_status": { "type": "string" }
      }
    },
    "adapter": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "mode": { "type": "string", "const": "local_json_dry_run" }
      }
    },
    "collections": {
      "type": "object",
      "properties": {
        "scan_runs": { "type": "array" },
        "findings": { "type": "array" },
        "inventory_components": { "type": "array" },
        "review_items": { "type": "array" },
        "import_ledger": { "type": "array" }
      }
    },
    "counts": {
      "type": "object",
      "properties": {
        "scan_run_count": { "type": "integer" },
        "finding_count": { "type": "integer" },
        "inventory_component_count": { "type": "integer" },
        "review_item_count": { "type": "integer" },
        "ledger_entry_count": { "type": "integer" }
      }
    },
    "safety": {
      "type": "object",
      "properties": {
        "no_database_writes": { "type": "boolean" },
        "no_live_ingestion": { "type": "boolean" },
        "no_external_fetching": { "type": "boolean" },
        "local_filesystem_only": { "type": "boolean" },
        "secrets_redacted": { "type": "boolean" }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  }
}
