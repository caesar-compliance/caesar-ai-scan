{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Caesar Scan Run",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_tool": {
      "type": "string"
    },
    "source_tool_version": {
      "type": "string"
    },
    "target_project": {
      "type": "string"
    },
    "target_hash": {
      "type": "string"
    },
    "scan_result_ref": {
      "type": "string"
    },
    "review_workflow_ref": {
      "type": "string"
    },
    "export_pack_ref": {
      "type": "string"
    },
    "scope_summary": {
      "type": "object"
    },
    "findings_summary": {
      "type": "object"
    },
    "safety_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "generated_at",
    "source_tool",
    "source_tool_version",
    "target_project",
    "scan_result_ref"
  ]
}